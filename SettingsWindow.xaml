<Window x:Class="OdevTakip2.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ayarlar" Height="580" Width="600"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">

            <!-- ── Tab 1: WhatsApp Grupları ───────────────────────────────── -->
            <TabItem Header="WhatsApp Grupları">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Foreground="Gray" FontSize="11" Margin="0,0,0,6"
                               Text="Her grup için ad ve kurum tipi belirtin:"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding WhatsAppGroupItems, RelativeSource={RelativeSource AncestorType=Window}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="28"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Height="26" Margin="0,0,4,0"
                                                 VerticalContentAlignment="Center"
                                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                                        <ComboBox Grid.Column="1" Height="26" Margin="0,0,4,0"
                                                  ItemsSource="{Binding InstitutionTypes, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  SelectedItem="{Binding InstitutionType, UpdateSourceTrigger=PropertyChanged}"/>
                                        <Button Grid.Column="2" Content="✕" Height="26"
                                                Foreground="OrangeRed" FontWeight="Bold"
                                                Tag="{Binding}" Click="BtnRemoveGroup_Click"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <Button Grid.Row="2" Content="+ Grup Ekle" Width="110" Height="28"
                            HorizontalAlignment="Left" Margin="0,6,0,0" Click="BtnAddGroup_Click"/>
                </Grid>
            </TabItem>

            <!-- ── Tab 2: E12 Sistemi ─────────────────────────────────────── -->
            <TabItem Header="E12 Sistemi">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Foreground="Gray" FontSize="11" Margin="0,0,0,6"
                               Text="Birden fazla E12 hesabı ekleyebilirsiniz (okul + dershane gibi):"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding E12AccountItems, RelativeSource={RelativeSource AncestorType=Window}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#CCC" BorderThickness="1" CornerRadius="3"
                                            Margin="0,3" Padding="6">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <!-- Row 0: Org + Type + Remove -->
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="150"/>
                                                    <ColumnDefinition Width="28"/>
                                                </Grid.ColumnDefinitions>
                                                <ComboBox Grid.Column="0" Height="26" Margin="0,0,4,0"
                                                          ItemsSource="{Binding Organizations, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          DisplayMemberPath="Name" SelectedValuePath="Id"
                                                          SelectedValue="{Binding OrganizationId, UpdateSourceTrigger=PropertyChanged}"/>
                                                <ComboBox Grid.Column="1" Height="26" Margin="0,0,4,0"
                                                          ItemsSource="{Binding InstitutionTypes, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          SelectedItem="{Binding InstitutionType, UpdateSourceTrigger=PropertyChanged}"/>
                                                <Button Grid.Column="2" Content="✕" Height="26"
                                                        Foreground="OrangeRed" FontWeight="Bold"
                                                        Tag="{Binding}" Click="BtnRemoveE12Account_Click"/>
                                            </Grid>
                                            <!-- Row 1: Username + Password -->
                                            <Grid Grid.Row="1" Margin="0,4,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Label Grid.Column="0" Content="Kullanıcı:" VerticalAlignment="Center" Padding="0,0,4,0"/>
                                                <TextBox Grid.Column="1" Height="24" Margin="0,0,8,0"
                                                         VerticalContentAlignment="Center"
                                                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>
                                                <Label Grid.Column="2" Content="Parola:" VerticalAlignment="Center" Padding="0,0,4,0"/>
                                                <TextBox Grid.Column="3" Height="24"
                                                         VerticalContentAlignment="Center"
                                                         Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <Button Grid.Row="2" Content="+ Hesap Ekle" Width="110" Height="28"
                            HorizontalAlignment="Left" Margin="0,6,0,0" Click="BtnAddE12Account_Click"/>
                </Grid>
            </TabItem>

            <!-- ── Tab 3: Kurum Tipleri ───────────────────────────────────── -->
            <TabItem Header="Kurum Tipleri">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Foreground="Gray" FontSize="11" Margin="0,0,0,6"
                               Text="WhatsApp ve E12 formlarında çıkacak seçenekler:"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding InstitutionTypes, RelativeSource={RelativeSource AncestorType=Window}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="28"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding}" VerticalAlignment="Center" Margin="4,0"/>
                                        <Button Grid.Column="1" Content="✕" Height="26"
                                                Foreground="OrangeRed" FontWeight="Bold"
                                                Tag="{Binding}" Click="BtnRemoveInstitutionType_Click"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <Grid Grid.Row="2" Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtNewInstitutionType" Grid.Column="0" Height="28"
                                 Margin="0,0,4,0" VerticalContentAlignment="Center"/>
                        <Button Grid.Column="1" Content="Ekle" Height="28" Click="BtnAddInstitutionType_Click"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ── Tab 4: Ders Programı ───────────────────────────────────── -->
            <TabItem Header="Ders Programı">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,0,0,6"
                               Text="Her kurum tipi için ders programı görseli ekleyin. E12'den çekildiyse otomatik kullanılır."/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ScheduleItems, RelativeSource={RelativeSource AncestorType=Window}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#CCC" BorderThickness="1" CornerRadius="3"
                                            Margin="0,3" Padding="6">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <!-- Row 0: Type + Image path + Browse + Remove -->
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="150"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="28"/>
                                                </Grid.ColumnDefinitions>
                                                <ComboBox Grid.Column="0" Height="26" Margin="0,0,4,0"
                                                          ItemsSource="{Binding InstitutionTypes, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          SelectedItem="{Binding InstitutionType, UpdateSourceTrigger=PropertyChanged}"/>
                                                <TextBox Grid.Column="1" Height="26" Margin="0,0,4,0"
                                                         IsReadOnly="True" Background="#F0F0F0"
                                                         VerticalContentAlignment="Center"
                                                         Text="{Binding ImagePath}"/>
                                                <Button Grid.Column="2" Content="Gözat" Height="26" Margin="0,0,4,0"
                                                        Tag="{Binding}" Click="BtnBrowseScheduleEntry_Click"/>
                                                <Button Grid.Column="3" Content="✕" Height="26"
                                                        Foreground="OrangeRed" FontWeight="Bold"
                                                        Tag="{Binding}" Click="BtnRemoveScheduleEntry_Click"/>
                                            </Grid>
                                            <!-- Row 1: Analyze + Status -->
                                            <Grid Grid.Row="1" Margin="0,4,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0" Content="AI ile Analiz Et"
                                                        Height="26" Padding="8,0"
                                                        Tag="{Binding}" Click="BtnAnalyzeScheduleEntry_Click"/>
                                                <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                                           Margin="8,0,0,0" Foreground="Gray" FontSize="11"
                                                           Text="{Binding Status}"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <Button Grid.Row="2" Content="+ Ders Programı Ekle" Width="150" Height="28"
                            HorizontalAlignment="Left" Margin="0,6,0,0" Click="BtnAddScheduleEntry_Click"/>
                </Grid>
            </TabItem>

            <!-- ── Tab 5: AI Sağlayıcılar ────────────────────────────────── -->
            <TabItem Header="AI Sağlayıcılar">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,0,0,6"
                               Text="Her sağlayıcı için API anahtarı ve model girin. Öncelik: 1 = ilk denenir. Biri hata verirse sıradaki denenir."/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding AIProviderItems, RelativeSource={RelativeSource AncestorType=Window}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#CCC" BorderThickness="1" CornerRadius="3"
                                            Margin="0,3" Padding="6">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <!-- Row 0: ProviderType + Model + Priority + Enabled + Remove -->
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="70"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="28"/>
                                                </Grid.ColumnDefinitions>
                                                <ComboBox Grid.Column="0" Height="26" Margin="0,0,4,0"
                                                          ItemsSource="{Binding AIProviderTypeOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          SelectedItem="{Binding ProviderType, UpdateSourceTrigger=PropertyChanged}"/>
                                                <ComboBox Grid.Column="1" Height="26" Margin="0,0,4,0"
                                                          IsEditable="True"
                                                          ItemsSource="{Binding AvailableModels}"
                                                          Text="{Binding ModelId, UpdateSourceTrigger=PropertyChanged}"/>
                                                <ComboBox Grid.Column="2" Height="26" Margin="0,0,4,0"
                                                          ItemsSource="{Binding AIProviderPriorityOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          SelectedItem="{Binding Priority, UpdateSourceTrigger=PropertyChanged}"/>
                                                <CheckBox Grid.Column="3" Content="Aktif" VerticalAlignment="Center" Margin="0,0,6,0"
                                                          IsChecked="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}"/>
                                                <Button Grid.Column="4" Content="✕" Height="26"
                                                        Foreground="OrangeRed" FontWeight="Bold"
                                                        Tag="{Binding}" Click="BtnRemoveAIProvider_Click"/>
                                            </Grid>
                                            <!-- Row 1: API Key -->
                                            <Grid Grid.Row="1" Margin="0,4,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Label Grid.Column="0" Content="API Key:" VerticalAlignment="Center" Padding="0,0,4,0"/>
                                                <TextBox Grid.Column="1" Height="24" VerticalContentAlignment="Center"
                                                         Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,6,0,0">
                        <Button Content="+ Sağlayıcı Ekle" Width="130" Height="28" Click="BtnAddAIProvider_Click"/>
                        <Button x:Name="btnAiTest" Content="AI Sağlayıcılarını Test Et" Width="160" Height="28" Margin="10,0,0,0" Click="BtnAiTest_Click" Background="#FF3B3B" Foreground="White" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </TabItem>

        </TabControl>

        <Button x:Name="btnSave" Grid.Row="1" Content="Kaydet ve Kapat"
                Height="35" Width="150" HorizontalAlignment="Right"
                Margin="0,10,0,0" Click="BtnSave_Click"/>
    </Grid>
</Window>
